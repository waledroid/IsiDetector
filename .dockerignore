# Git
.git/
.gitignore

# Training data & outputs (volume-mounted at runtime — isidet/ bucket)
isidet/data/
isidet/runs/
isidet/models/
isidet/logs/

# MkDocs build artifacts
mkdocs/site/
**/__pycache__/
*.pyc
*.pyo

# Large binary files (anywhere in tree)
*.pt
*.pth
*.onnx
*.engine
*.bin

# Claude Code metadata and loose notes
.claude/
*.txt
!**/requirements*.txt

# Webapp runtime state (volume-mounted, not part of the image)
webapp/isitec_app/uploads/
webapp/isitec_app/logs/
webapp/isitec_app/settings.json
webapp/isitec_api/uploads/
webapp/isitec_api/logs/
webapp/isitec_api/settings.json

# IDE
.vscode/
.idea/
*.swp
