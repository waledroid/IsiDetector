# IsiDetector — runtime environment overrides
# Copy to .env and edit. Loaded by docker compose via ./up.sh.

# Dev-mode UI unlock password (protects /api/settings, /api/performance,
# /api/udp, /api/line). Change this before any production deployment.
DEV_PASSWORD=change-me

# UDP sort-trigger target. Overrides configs/train.yaml + hardcoded default.
# Set UDP_HOST to the sorter controller's IP if it's on a different machine.
#UDP_HOST=127.0.0.1
#UDP_PORT=9502
