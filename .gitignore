# Gitignore patterns updated for the 5-bucket restructure.
# The leading-slash patterns here (/isidet/...) anchor to the repo root so
# they match only the intended bucket path, not any nested directory that
# happens to share the name.

# ── isidet/ bucket — ML core, mostly large artefacts ────────────────────────
/isidet/data/
/isidet/logs/

# runs/ — exclude all training artefacts EXCEPT one specific trained model
# run we ship with the deploy branch so a single `git clone` gives the
# site PC a working detector out of the box (no scp / USB / cloud fetch
# needed). Each parent directory must be re-included before git recurses
# into its child — hence the layered chain below.
/isidet/runs/*
!/isidet/runs/segment/
/isidet/runs/segment/*
!/isidet/runs/segment/models/
/isidet/runs/segment/models/*
!/isidet/runs/segment/models/yolo/
/isidet/runs/segment/models/yolo/*
!/isidet/runs/segment/models/yolo/yolo26n_320_200/
!/isidet/runs/segment/models/yolo/yolo26n_320_200/**

# models/ — fully excluded on the deploy branch. Pretrained baselines
# (yolo26n.pt, yolov8m-seg.pt) live on the `main` branch as training
# inputs; site PCs never use them, only the exported / trained models
# under runs/.
/isidet/models/*

# ── webapp/ bucket — per-backend runtime state ──────────────────────────────
/webapp/isitec_app/uploads/
/webapp/isitec_api/uploads/
/webapp/isitec_api/logs/

# ── deploy/ bucket ──────────────────────────────────────────────────────────
# Per-host deployment marker written by run_start.sh
/deploy/.deployment.env

# ── compression/ bucket ─────────────────────────────────────────────────────
# Compression tool scratch outputs (if stages ever write to a central dir)
/compression/outputs/

# ── Model / weight artefacts anywhere in the tree ───────────────────────────
*.pth
*.onnx
*.pt

# Re-include every weight artefact inside the shipped trained model run.
# This rule must come AFTER the extension rules above since gitignore is
# last-match-wins.
!/isidet/runs/segment/models/yolo/yolo26n_320_200/**

# ── Python hygiene ──────────────────────────────────────────────────────────
**/__pycache__/
*.pyc
*.pyo
venv/
.venv/

# ── OS / editor noise ───────────────────────────────────────────────────────
.DS_Store

# ── Session-local diagnostics (not for shared repo) ─────────────────────────
/MODULAR.md
/ONNX_TUTORIAL.md
/OPENVINO_TUTORIAL.md
/isidet/a.py
